# Copy this file to .env and fill in real values.

# Anthropic API — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# Database — leave unset to fall back to a local SQLite file for basic
# testing, but point this at real PostgreSQL before touching courses/lessons
# (see the ARRAY column note in app/db_models.py).
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/monalearn

# Auth — generate a real secret with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Billing — from https://dashboard.stripe.com (test mode keys start with sk_test_/whsec_test_)
# Without these set, /api/billing/* returns a clear 500 rather than crashing.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_BASIC=price_your_basic_plan_price_id
STRIPE_PRICE_PROFESSIONAL=price_your_professional_plan_price_id
STRIPE_PRICE_PREMIUM=price_your_premium_plan_price_id
FRONTEND_URL=http://localhost:3000

